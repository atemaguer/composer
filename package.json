{
  "name": "composer-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:desktop": "turbo dev --filter=composer",
    "dev:web": "turbo dev --filter=web",
    "build": "turbo build",
    "build:web": "turbo build --filter=web",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "start:web": "turbo start --filter=web",
    "preview": "turbo preview --filter=composer",
    "server:build": "turbo server:build --filter=composer",
    "install-app-deps": "npm --workspace composer run install-app-deps",
    "electron:build:dir": "turbo electron:build:dir --filter=composer",
    "build:unpack": "turbo build:unpack --filter=composer",
    "build:win": "turbo build:win --filter=composer",
    "build:mac": "turbo build:mac --filter=composer",
    "build:mac:dev": "turbo build:mac:dev --filter=composer",
    "build:linux": "turbo build:linux --filter=composer"
  },
  "devDependencies": {
    "turbo": "^2.8.0"
  }
}
