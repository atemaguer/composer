{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "outDir": "dist-server",
    "rootDir": "src-server",
    "types": ["node"]
  },
  "include": ["src-server/**/*.ts"]
}
