{
  "name": "@composer/cli",
  "version": "0.1.0",
  "private": true,
  "description": "Composer non-interactive CLI",
  "type": "module",
  "bin": {
    "composer": "./dist/index.js"
  },
  "dependencies": {
    "@composer/client": "file:../../packages/composer-client"
  },
  "scripts": {
    "build": "npm --workspace @composer/client run build && tsc -p tsconfig.json",
    "typecheck": "npm --workspace @composer/client run build && tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs"
  }
}
