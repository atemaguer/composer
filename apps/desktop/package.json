{
  "name": "composer",
  "version": "0.1.1",
  "private": true,
  "description": "Composer desktop app",
  "author": "Atem Atem",
  "homepage": "https://github.com/atemaguer/composer",
  "main": "dist-electron/main.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"tsc -p tsconfig.electron.json --watch\" \"tsc -p tsconfig.server.json --watch\" \"wait-on tcp:5173 file:dist-electron/main.js file:dist-server/server/index.js && electron .\"",
    "server:dev": "tsc -p tsconfig.server.json --watch",
    "server:build": "tsc -p tsconfig.server.json",
    "build": "tsc -p tsconfig.electron.json && tsc -p tsconfig.server.json && vite build",
    "install-app-deps": "electron-builder install-app-deps",
    "electron:build:win": "electron-builder --win",
    "electron:build:mac": "electron-builder --mac",
    "electron:build:mac:dev": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "electron:build:linux": "electron-builder --linux",
    "electron:build:dir": "electron-builder --dir",
    "build:unpack": "run-s build electron:build:dir",
    "build:win": "run-s build electron:build:win",
    "build:mac": "run-s build electron:build:mac",
    "build:mac:dev": "run-s build electron:build:mac:dev",
    "build:linux": "run-s build electron:build:linux",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.177",
    "@anthropic-ai/claude-agent-sdk": "^0.2.128",
    "@base-ui/react": "^1.4.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@fontsource-variable/geist": "^5.2.8",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^6.0.174",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "shadcn": "^4.6.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "41.4.0",
    "electron-builder": "^26.0.12",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}
