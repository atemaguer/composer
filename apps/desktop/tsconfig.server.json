{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "dist-server",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "server/index.ts",
    "server/composer-server.ts",
    "server/capabilities.ts",
    "server/provider-factories.ts",
    "server/runtime.ts",
    "server/runtime-persistence.ts",
    "server/desktop-persistence.ts",
    "server/providers/**/*.ts",
    "electron/session-loader.ts",
    "src/types.ts"
  ]
}
