{
  "name": "@composer/runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Composer runtime, server, providers, and local session persistence",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server-entry": {
      "types": "./dist/server-entry.d.ts",
      "default": "./dist/server-entry.js"
    },
    "./providers/codex": {
      "types": "./dist/providers/codex.d.ts",
      "default": "./dist/providers/codex.js"
    },
    "./providers/claude": {
      "types": "./dist/providers/claude.d.ts",
      "default": "./dist/providers/claude.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./review-diff": {
      "types": "./dist/review-diff.d.ts",
      "default": "./dist/review-diff.js"
    },
    "./parallel-worktrees": {
      "types": "./dist/parallel-worktrees.d.ts",
      "default": "./dist/parallel-worktrees.js"
    },
    "./composer-session-registry": {
      "types": "./dist/composer-session-registry.d.ts",
      "default": "./dist/composer-session-registry.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "default": "./dist/storage/index.js"
    },
    "./storage/composer-home": {
      "types": "./dist/storage/composer-home.d.ts",
      "default": "./dist/storage/composer-home.js"
    },
    "./storage/composer-session-registry": {
      "types": "./dist/storage/composer-session-registry.d.ts",
      "default": "./dist/storage/composer-session-registry.js"
    },
    "./session-loader": {
      "types": "./dist/session-loader.d.ts",
      "default": "./dist/session-loader.js"
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.128",
    "@composer/client": "0.1.0",
    "ai": "^6.0.174",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  },
  "scripts": {
    "build": "npm --workspace @composer/client run build && tsc -p tsconfig.json",
    "typecheck": "npm --workspace @composer/client run build && tsc -p tsconfig.json --noEmit"
  }
}
